# ============================================================
#  Gradient Backend — Environment Variables Example
#  คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับเครื่องของคุณ
#  cp .env.example .env
# ============================================================

# ─── App ────────────────────────────────────────────────────
APP_ENV=development                   # development | production

# ─── CMS Service (HTTP) ─────────────────────────────────────
CMS_PORT=8080

# ─── Grader Service (gRPC) ──────────────────────────────────
GRADER_PORT=8081
GRADER_ADDR=localhost:8081            # ที่อยู่ gRPC ของ Grader (CMS ใช้ connect)
GRADER_SANDBOX_PROFILE_PATH=./config/sandbox_profiles.yaml

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=gradient_user
POSTGRES_PASSWORD=gradient_pass
POSTGRES_DB=gradient
POSTGRES_SSLMODE=disable              # disable | require | verify-full

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_EXPIRES_IN=24h                    # รูปแบบ Go duration: 1h, 24h, 168h
